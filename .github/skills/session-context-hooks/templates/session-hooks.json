{
  "hooks": {
    "PreCompact": [
      {
        "type": "command",
        "command": "bash .github/hooks/scripts/collect-context.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File .github\\hooks\\scripts\\collect-context.ps1",
        "timeout": 15
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash .github/hooks/scripts/save-session.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File .github\\hooks\\scripts\\save-session.ps1",
        "timeout": 15
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "bash .github/hooks/scripts/restore-session.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File .github\\hooks\\scripts\\restore-session.ps1",
        "timeout": 10
      }
    ]
  }
}
