{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "echo Validating tool usage...",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "npx eslint --fix ${file}",
        "windows": "npx eslint --fix %file%",
        "timeout": 30
      }
    ]
  }
}
